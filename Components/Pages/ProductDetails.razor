@page "/products/{Id:int}"
@rendermode InteractiveServer
@inject IProductService ProductService
@inject ICartService CartService
@inject ICurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>@(part?.Name ?? "Запчасть") — АвтоМаркет</PageTitle>

<div class="container py-4">
@if (part == null)
{
    <p><em>Загрузка...</em></p>
}
else
{
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" style="color:#c62828;">Главная</a></li>
            <li class="breadcrumb-item"><a href="/products" style="color:#c62828;">Каталог</a></li>
            <li class="breadcrumb-item active">@part.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        @* Изображение *@
        <div class="col-lg-5">
            <div class="detail-image-wrap">
                @if (!string.IsNullOrEmpty(part.ImageUrl))
                {
                    <img src="@part.ImageUrl" class="img-fluid rounded" alt="@part.Name" style="max-height:380px; object-fit:contain;" />
                }
                else
                {
                    <div style="height:280px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-gear" style="font-size:6rem;color:#ddd;"></i>
                    </div>
                }
                <div class="mt-3 text-center">
                    <span class="badge" style="background:#c62828;">@part.Category?.Name</span>
                </div>
            </div>
        </div>

        @* Информация и цена *@
        <div class="col-lg-7">
            <h2 class="fw-bold mb-1" style="color:#1a1a1a;">@part.Name</h2>
            <p class="text-muted mb-4">@part.Description</p>

            @* Вкладки: описание / характеристики *@
            <ul class="nav detail-tabs border-bottom mb-3">
                <li class="nav-item">
                    <a class="nav-link @(activeTab == "desc" ? "active" : "")" href="#" @onclick:preventDefault
                       @onclick='() => activeTab = "desc"'>Описание</a>
                </li>
                @if (part.Details != null)
                {
                    <li class="nav-item">
                        <a class="nav-link @(activeTab == "specs" ? "active" : "")" href="#" @onclick:preventDefault
                           @onclick='() => activeTab = "specs"'>Характеристики</a>
                    </li>
                }
            </ul>

            @if (activeTab == "desc")
            {
                <p style="color:#444; line-height:1.7;">@part.Description</p>
                <p style="color:#666; font-size:0.9rem;">В наличии: <strong>@part.Stock шт.</strong></p>
            }
            else if (activeTab == "specs" && part.Details != null)
            {
                <div>
                    @if (!string.IsNullOrEmpty(part.Details.Manufacturer))
                    {
                        <div class="spec-row">
                            <span class="spec-label">Производитель</span>
                            <span class="spec-value">@part.Details.Manufacturer</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(part.Details.CountryOfOrigin))
                    {
                        <div class="spec-row">
                            <span class="spec-label">Страна</span>
                            <span class="spec-value">@part.Details.CountryOfOrigin</span>
                        </div>
                    }
                    @if (part.Details.Weight.HasValue)
                    {
                        <div class="spec-row">
                            <span class="spec-label">Вес</span>
                            <span class="spec-value">@part.Details.Weight кг</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(part.Details.Dimensions))
                    {
                        <div class="spec-row">
                            <span class="spec-label">Размеры</span>
                            <span class="spec-value">@part.Details.Dimensions</span>
                        </div>
                    }
                    @if (part.Details.WarrantyMonths > 0)
                    {
                        <div class="spec-row">
                            <span class="spec-label">Гарантия</span>
                            <span class="spec-value">@part.Details.WarrantyMonths мес.</span>
                        </div>
                    }
                </div>
            }

            @* Блок цены и кнопки *@
            <div class="detail-price-box mt-4">
                <div class="price">@part.Price.ToString("N0") ₽</div>
                <div class="stock-info">
                    @if (part.Stock > 0)
                    {
                        <span><i class="bi bi-check-circle-fill" style="color:#4caf50;"></i> В наличии: @part.Stock шт.</span>
                    }
                    else
                    {
                        <span style="color:#f44336;"><i class="bi bi-x-circle-fill"></i> Нет в наличии</span>
                    }
                </div>
                <button class="btn btn-primary btn-lg w-100 mt-3" @onclick="AddToCart" disabled="@(part.Stock == 0)">
                    <i class="bi bi-cart-plus me-2"></i> Добавить в корзину
                </button>
                <a href="/products" class="btn btn-outline-secondary w-100 mt-2" style="color:#aaa; border-color:#444;">
                    <i class="bi bi-arrow-left me-1"></i> Вернуться в каталог
                </a>
            </div>
        </div>
    </div>
}
</div>

@code {
    [Parameter] public int Id { get; set; }
    private Models.Product? part;
    private string activeTab = "desc";

    protected override async Task OnInitializedAsync()
    {
        part = await ProductService.GetByIdAsync(Id);
        if (part?.Details != null) activeTab = "specs";
    }

    private async Task AddToCart()
    {
        if (part == null) return;
        var buyer = await CurrentUser.GetOrCreateDemoCustomerAsync();
        await CartService.AddToCartAsync(buyer.Id, part.Id);
        Nav.NavigateTo("/cart");
    }
}
